CHIP Test16 {
    IN in[16];
    OUT out;

    PARTS:
    Or4(a=in[0], b=in[1], c=in[2], d=in[3], out=p1);
    Or4(a=in[4], b=in[5], c=in[6], d=in[7], out=p2);
    Or4(a=in[8], b=in[9], c=in[10], d=in[11], out=p3);
    Or4(a=in[12], b=in[13], c=in[14], d=in[15], out=p4);
    Or4(a=p1, b=p2, c=p3, d=p4, out=out);
}